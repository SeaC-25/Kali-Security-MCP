# Kali MCP 轻量版 Docker 镜像
# 仅包含最常用的工具，适合快速部署和CTF比赛
#
# 构建: docker build -t kali-mcp:slim -f docker/Dockerfile.slim .
# 运行: docker run -it --rm kali-mcp:slim

FROM python:3.11-slim-bookworm

LABEL maintainer="Kali MCP Team"
LABEL version="2.0.0-slim"
LABEL description="Lightweight Kali MCP server for CTF"

# 设置环境变量
ENV PYTHONUNBUFFERED=1
ENV KALI_MCP_DATA_DIR=/data
ENV DEBIAN_FRONTEND=noninteractive

# 安装基础依赖
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    wget \
    git \
    netcat-openbsd \
    dnsutils \
    whois \
    && rm -rf /var/lib/apt/lists/*

# 安装核心扫描工具
RUN apt-get update && apt-get install -y --no-install-recommends \
    nmap \
    nikto \
    sqlmap \
    hydra \
    john \
    binwalk \
    && rm -rf /var/lib/apt/lists/*

# 安装Go工具 (gobuster, nuclei, ffuf等)
RUN apt-get update && apt-get install -y --no-install-recommends golang && \
    go install github.com/OJ/gobuster/v3@latest && \
    go install github.com/projectdiscovery/nuclei/v3/cmd/nuclei@latest && \
    go install github.com/ffuf/ffuf@latest && \
    go install github.com/projectdiscovery/subfinder/v2/cmd/subfinder@latest && \
    mv /root/go/bin/* /usr/local/bin/ && \
    rm -rf /root/go && \
    apt-get remove -y golang && \
    apt-get autoremove -y && \
    rm -rf /var/lib/apt/lists/*

# 创建工作目录
WORKDIR /app

# 复制项目文件
COPY requirements.txt /app/
RUN pip3 install --no-cache-dir -r requirements.txt || \
    pip3 install --no-cache-dir mcp flask flask-cors jinja2

COPY kali_mcp/ /app/kali_mcp/
COPY mcp_server.py /app/
COPY fast_config.py /app/
COPY connection_pool.py /app/

# 创建数据目录
RUN mkdir -p /data/learning /data/reports /data/cache /data/logs

# 下载常用字典
RUN mkdir -p /usr/share/wordlists && \
    curl -sL https://raw.githubusercontent.com/danielmiessler/SecLists/master/Discovery/Web-Content/common.txt \
    -o /usr/share/wordlists/common.txt && \
    curl -sL https://raw.githubusercontent.com/danielmiessler/SecLists/master/Discovery/Web-Content/directory-list-2.3-small.txt \
    -o /usr/share/wordlists/directory-list-small.txt

# 健康检查
HEALTHCHECK --interval=60s --timeout=10s --retries=3 \
    CMD python3 -c "import socket; s=socket.socket(); s.connect(('localhost',8080)); s.close()" || exit 1

# 暴露端口
EXPOSE 8080

# 默认命令
CMD ["python3", "-m", "kali_mcp.main"]
